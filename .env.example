# MySQL — Smart Factory databases
# All four databases share the same host/user/password.
MYSQL_HOST=192.168.3.xxx
MYSQL_PORT=3306
MYSQL_USER=sf_user
MYSQL_PASSWORD=your_password

# NextAuth — generate a random secret: `openssl rand -base64 32`
NEXTAUTH_SECRET=change_me_to_a_long_random_string
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — create credentials at https://console.cloud.google.com/
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
